{% extends 'partials/base.html.twig' %}
{% block content %}
<div class="page-hero"><div class="container">
  <h1>{{ page.title }}</h1>
  {% if page.header.untertitel %}<p>{{ page.header.untertitel }}</p>{% endif %}
</div></div>

<section class="section" style="padding-top:0;"><div class="container">
  <div class="news-grid">
    {% for item in page.collection %}
    <div class="news-card"><div class="news-card-body">
      <div class="news-date">{{ item.date|date('d.m.Y') }}</div>
      <h3>{{ item.title }}</h3>
      <p>{{ (item.header.teaser ?: item.summary)|striptags|truncate(160) }}</p>
      <a class="read-more" href="{{ item.url }}">Weiterlesen →</a>
    </div></div>
    {% endfor %}
  </div>
</div></section>
{% endblock %}
