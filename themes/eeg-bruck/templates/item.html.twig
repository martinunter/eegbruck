{% extends 'partials/base.html.twig' %}
{% block content %}
<div class="page-hero"><div class="container">
  <h1>{{ page.title }}</h1>
  <p>{{ page.date|date('d.m.Y') }}</p>
</div></div>
<article class="content-section">
  {{ content|raw }}
  <p style="margin-top:2rem;"><a href="{{ page.parent.url }}" class="btn btn-outline">← Zurück zu Aktuelles</a></p>
</article>
{% endblock %}
